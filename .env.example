# =============================================================
#  我的计算森林 — 环境变量模板
# =============================================================
# 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
# =============================================================

# --- DeepSeek 直连 ---
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODE=official
DEEPSEEK_MODEL=deepseek-chat

# --- 智谱 GLM ---
GLM_API_KEY=sk-your-glm-key
GLM_MODEL=glm-4-flash

# --- Dify Cloud ---
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_ENABLED=false
DIFY_API_KEY=
DIFY_WORKFLOW_GUIDANCE_KEY=
DIFY_WORKFLOW_SUMMARY_KEY=
DIFY_WORKFLOW_GRADING_KEY=
DIFY_WORKFLOW_PROFILE_KEY=
DIFY_WORKFLOW_PROBLEM_KEY=

